{
  "tslint-disable": {
    "prefix": "tslint-disable",
    "body": [
      "/* eslint-disable @typescript-eslint/${1|INSERT_RULES|} */",
      "$0/* eslint-enable ${1} */"
    ],
    "description": "Typescript ESLint disable wrapper"
  },
  "tslint-disable-line": {
    "prefix": "tslint-disable-line",
    "body": ["// eslint-disable-line @typescript-eslint/${1|INSERT_RULES|}"],
    "description": "Typescript ESLint disable line"
  },
  "tslint-disable-next-line": {
    "prefix": "tslint-disable-next-line",
    "body": ["// eslint-disable-next-line @typescript-eslint/${1|INSERT_RULES|}"],
    "description": "Typescript ESLint disable next line"
  }
}
