{
  "name": "eslint-disable-typescript-snippets",
  "displayName": "eslint-disable-typescript-snippets",
  "description": "Snippets for disabling @typescript-eslint rules",
  "version": "1.0.0",
  "publisher": "ArthurNeuman",
  "author": "exoRift",
  "engines": {
    "vscode": "^1.12.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/exoRift/eslint-disable-typescript-snippets"
  },
  "categories": [
    "Snippets"
  ],
  "scripts": {
    "build": "node ./build.js"
  },
  "icon": "images/icon.png",
  "contributes": {
    "snippets": [
      {
        "language": "javascript",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "javascriptreact",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "typescript",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "typescriptreact",
        "path": "./snippets/snippets.json"
      },
      {
        "language": "vue",
        "path": "./snippets/snippets.json"
      }
    ]
  }
}
